<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tulipplus.auth.mapper.RefreshTokenMapper">

    <resultMap id="RTResult" type="com.tulipplus.auth.domain.RefreshToken">
        <id     property="id"        column="id"/>
        <result property="userId"    column="user_id"/>
        <result property="token"     column="token"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.tulipplus.auth.domain.RefreshToken"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tulip.refresh_tokens (user_id, token, expires_at)
        VALUES (#{userId}, #{token}, #{expiresAt})
    </insert>

    <select id="findByToken" resultMap="RTResult">
        SELECT id, user_id, token, expires_at, created_at
          FROM tulip.refresh_tokens
         WHERE token = #{token}
    </select>

    <delete id="deleteByToken">
        DELETE FROM tulip.refresh_tokens WHERE token = #{token}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM tulip.refresh_tokens WHERE user_id = #{userId}
    </delete>

</mapper>
